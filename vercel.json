{
  "buildCommand": "mkdir -p .vercel/output && cp -r . .vercel/output/static/",
  "outputDirectory": ".vercel/output/static",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "index.html"
    },
    {
      "source": "/contact",
      "destination": "src/components/contact.html"
    },
    {
      "source": "/contact.html",
      "destination": "src/components/contact.html"
    },
    {
      "source": "/case-studies",
      "destination": "src/components/case-studies.html"
    },
    {
      "source": "/case-studies.html",
      "destination": "src/components/case-studies.html"
    },
    {
      "source": "/saasdirectories",
      "destination": "src/components/saas-directories.html"
    },
    {
      "source": "/saasdirectories/:path*",
      "destination": "src/components/saas-directories.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/data/directories.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
