{
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/directories", "destination": "/resources/free-directories", "permanent": true },
    { "source": "/saasdirectories", "destination": "/resources/saas-directories", "permanent": true },
    { "source": "/aidirectories", "destination": "/resources/ai-directories", "permanent": true },
    { "source": "/guest-posts", "destination": "/resources/guest-post-sites", "permanent": true }
  ],
  "rewrites": [
    { "source": "/contact", "destination": "/pages/contact" },
    { "source": "/case-studies", "destination": "/pages/case-studies" },
    { "source": "/resources", "destination": "/pages/resources" },
    { "source": "/resources/open-startup-backlink-lists", "destination": "/pages/open-startup-backlink-lists" },
    { "source": "/resources/free-directories", "destination": "/pages/directories" },
    { "source": "/resources/saas-directories", "destination": "/pages/saasdirectories" },
    { "source": "/resources/ai-directories", "destination": "/pages/aidirectories" },
    { "source": "/resources/guest-post-sites", "destination": "/pages/guest-posts" },
    { "source": "/sitemap.xml", "destination": "/pages/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/pages/robots.txt" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/data/directories.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
