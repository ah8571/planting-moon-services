{
  "outputDirectory": "public",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/contact", "destination": "/pages/contact.html" },
    { "source": "/case-studies", "destination": "/pages/case-studies.html" },
    { "source": "/guest-posts", "destination": "/pages/guest-posts.html" },
    { "source": "/saasdirectories", "destination": "/pages/saasdirectories.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/data/directories.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
